<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Trapezohe Companion Installer"
    Manufacturer="Trapezohe"
    Language="1033"
    Version="$(var.ProductVersion)"
    UpgradeCode="{4AF4D4EF-2C1D-4FB9-99EB-387DABEE6D20}">

    <!-- Schedule="afterInstallExecute": keep old files until after InstallFiles so
         StopTrayBeforeInstall can execute the old run-install.cmd to stop the tray,
         then InstallFiles overwrites them (tray is stopped, no file lock), and finally
         RemoveExistingProducts cleans up old registry entries. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes" Schedule="afterInstallExecute" DowngradeErrorMessage="A newer Trapezohe Companion Installer is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="$(var.InstallerSourceDir)/license.rtf" />
    <ui:WixUI Id="WixUI_Minimal" />

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="TrapezoheCompanion" />
    </StandardDirectory>

    <Component Id="RunInstallCmdComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="RunInstallCmd" Source="$(var.InstallerSourceDir)/run-install.cmd" KeyPath="yes" />
    </Component>

    <Component Id="InstallCompanionPs1Component" Directory="INSTALLFOLDER" Guid="*">
      <File Id="InstallCompanionPs1" Source="$(var.InstallerSourceDir)/install-companion.ps1" KeyPath="yes" />
    </Component>

    <Component Id="CompanionPackageComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="CompanionPackage" Source="$(var.InstallerSourceDir)/trapezohe-companion-package.tgz" KeyPath="yes" />
    </Component>

    <Component Id="TrayExeComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="TrayExe" Source="$(var.InstallerSourceDir)/trapezohe-companion-tray.exe" KeyPath="yes" />
    </Component>

    <Component Id="TrayReadmeComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="TrayReadme" Source="$(var.InstallerSourceDir)/tray.README.txt" KeyPath="yes" />
    </Component>

    <Feature Id="MainFeature" Title="Companion Installer" Level="1">
      <ComponentRef Id="RunInstallCmdComponent" />
      <ComponentRef Id="InstallCompanionPs1Component" />
      <ComponentRef Id="CompanionPackageComponent" />
      <ComponentRef Id="TrayExeComponent" />
      <ComponentRef Id="TrayReadmeComponent" />
    </Feature>

    <CustomAction
      Id="StopTrayBeforeInstall"
      FileRef="RunInstallCmd"
      ExeCommand="-StopTrayOnly"
      Execute="deferred"
      Return="ignore"
      Impersonate="yes" />

    <CustomAction
      Id="RunCompanionBootstrap"
      FileRef="RunInstallCmd"
      ExeCommand=""
      Execute="deferred"
      Return="check"
      Impersonate="yes" />

    <CustomAction
      Id="UninstallCleanup"
      FileRef="RunInstallCmd"
      ExeCommand="-Cleanup"
      Execute="deferred"
      Return="ignore"
      Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="StopTrayBeforeInstall" Before="InstallFiles" Condition="(Installed OR WIX_UPGRADE_DETECTED) AND NOT REMOVE~=&quot;ALL&quot;" />
      <Custom Action="RunCompanionBootstrap" After="InstallFiles" Condition="NOT REMOVE~=&quot;ALL&quot;" />
      <Custom Action="UninstallCleanup" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
