#!/bin/bash
set -euo pipefail

VERSION="__COMPANION_VERSION__"
LOG_FILE="/Users/Shared/trapezohe-companion-installer.log"
CONSOLE_USER="$(stat -f %Su /dev/console 2>/dev/null || true)"

{
  echo "[$(date)] Companion macOS installer started (version=${VERSION})"
  echo "[$(date)] Console user: ${CONSOLE_USER:-unknown}"
} >> "${LOG_FILE}" 2>&1

if [[ -z "${CONSOLE_USER}" || "${CONSOLE_USER}" == "root" ]]; then
  echo "[$(date)] No valid console user found; skipping bootstrap." >> "${LOG_FILE}" 2>&1
  exit 0
fi

# The postinstall runs as root, so mktemp -t lands under a root-only temp directory.
# Put the bootstrap script in /Users/Shared so the console user can execute it via su.
TMP_SCRIPT="$(mktemp "/Users/Shared/trapezohe-companion-bootstrap.XXXXXX")"
cat > "${TMP_SCRIPT}" <<'EOS'
#!/bin/bash
set -euo pipefail

TRAPEZOHE_DIR="$HOME/.trapezohe"
TRAY_APP_PATH="/Applications/Trapezohe Companion.app"
TRAY_BIN_PATH="${TRAY_APP_PATH}/Contents/MacOS/trapezohe-companion-tray"
APP_RUNTIME_DIR="${TRAY_APP_PATH}/Contents/Resources/companion"
APP_NODE_DIR="${TRAY_APP_PATH}/Contents/Resources/runtime/node"
TRAY_AGENT_PATH="$HOME/Library/LaunchAgents/ai.trapezohe.companion.tray.plist"
LEGACY_DAEMON_AGENT_PATH="$HOME/Library/LaunchAgents/ai.trapezohe.companion.plist"
STARTUP_POLICY_PATH="$TRAPEZOHE_DIR/companion-startup.json"
LEGACY_TRAY_PREFS_PATH="$TRAPEZOHE_DIR/companion-tray.json"

log() {
  echo "[$(date)] $*"
}

resolve_app_node() {
  local node_bin="${APP_NODE_DIR}/bin/node"
  if [[ -x "${node_bin}" ]]; then
    echo "${node_bin}"
    return 0
  fi
  log "Bundled app Node.js missing at ${node_bin}"
  return 1
}

write_startup_policy() {
  mkdir -p "${TRAPEZOHE_DIR}"
  cat > "${STARTUP_POLICY_PATH}" <<'JSON'
{
  "loginItem": "tray",
  "ensureDaemonOnTrayLaunch": true
}
JSON
  rm -f "${LEGACY_TRAY_PREFS_PATH}"
  log "Wrote unified tray startup policy to ${STARTUP_POLICY_PATH}"
}

remove_legacy_daemon_login_item() {
  launchctl unload "${LEGACY_DAEMON_AGENT_PATH}" >/dev/null 2>&1 || true
  rm -f "${LEGACY_DAEMON_AGENT_PATH}"
  log "Removed legacy daemon login item if present"
}

register_tray_login_item() {
  mkdir -p "$(dirname "${TRAY_AGENT_PATH}")"
  cat > "${TRAY_AGENT_PATH}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.trapezohe.companion.tray</string>
  <key>ProgramArguments</key>
  <array>
    <string>${TRAY_BIN_PATH}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>${TRAPEZOHE_DIR}/companion-tray.log</string>
  <key>StandardErrorPath</key>
  <string>${TRAPEZOHE_DIR}/companion-tray.error.log</string>
</dict>
</plist>
PLIST
  launchctl unload "${TRAY_AGENT_PATH}" >/dev/null 2>&1 || true
  launchctl load "${TRAY_AGENT_PATH}" >/dev/null 2>&1 || true
  log "Registered tray login item via ${TRAY_AGENT_PATH}"
}

ensure_companion_config() {
  local config_file="${TRAPEZOHE_DIR}/companion.json"
  if [[ -f "${config_file}" ]]; then
    log "Config already exists: ${config_file}"
    return 0
  fi

  mkdir -p "${TRAPEZOHE_DIR}"
  local token
  token="$(openssl rand -hex 24)"
  cat > "${config_file}" <<JSON
{
  "port": 41591,
  "token": "${token}",
  "mcpServers": {},
  "permissionPolicy": {
    "mode": "workspace",
    "workspaceRoots": ["$HOME/trapezohe-workspace"]
  }
}
JSON
  chmod 600 "${config_file}"
  mkdir -p "$HOME/trapezohe-workspace"
  log "Created config with auto-generated token: ${config_file}"
}

register_native_host() {
  local node_bin
  if ! node_bin="$(resolve_app_node)"; then
    log "Bundled app Node.js not available; skipping native host registration"
    return 0
  fi

  local src_script="${APP_RUNTIME_DIR}/bin/native-host.mjs"

  if [[ ! -f "${src_script}" ]]; then
    log "Native host script not found at ${src_script}; skipping"
    return 0
  fi

  local launcher="${TRAPEZOHE_DIR}/native-host-launcher.sh"
  mkdir -p "${TRAPEZOHE_DIR}"
  cat > "${launcher}" <<LAUNCHER
#!/bin/sh
exec "${node_bin}" "${src_script}" "\$@"
LAUNCHER
  chmod 755 "${launcher}"

  # Write Chrome NativeMessagingHosts manifests
  local ext_id="nnhdkkgpoeojjddikcjadgpkbfbjhcal"
  local origin="chrome-extension://${ext_id}/"
  local host_names=("com.ghast.companion" "com.trapezohe.companion")
  local browser_dirs=(
    "$HOME/Library/Application Support/Google/Chrome/NativeMessagingHosts"
    "$HOME/Library/Application Support/BraveSoftware/Brave-Browser/NativeMessagingHosts"
    "$HOME/Library/Application Support/Chromium/NativeMessagingHosts"
    "$HOME/Library/Application Support/Microsoft Edge/NativeMessagingHosts"
  )

  for host_name in "${host_names[@]}"; do
    for dir in "${browser_dirs[@]}"; do
      mkdir -p "${dir}"
      cat > "${dir}/${host_name}.json" <<MANIFEST
{
  "name": "${host_name}",
  "description": "Ghast Companion — local runtime bridge for the Ghast browser extension",
  "path": "${launcher}",
  "type": "stdio",
  "allowed_origins": [
    "${origin}"
  ]
}
MANIFEST
    done
  done

  log "Registered native messaging host for extension ${ext_id}"
}

restart_companion_daemon() {
  local node_bin
  if ! node_bin="$(resolve_app_node)"; then
    log "Bundled app Node.js missing; skipping runtime handoff"
    return 0
  fi

  if [[ ! -f "${APP_RUNTIME_DIR}/bin/cli.mjs" ]]; then
    log "Bundled companion CLI missing at ${APP_RUNTIME_DIR}/bin/cli.mjs; skipping runtime handoff"
    return 0
  fi

  if [[ ! -f "${TRAPEZOHE_DIR}/companion.json" ]]; then
    log "Companion config missing; skipping runtime handoff"
    return 0
  fi

  if "${node_bin}" "${APP_RUNTIME_DIR}/bin/cli.mjs" stop --force >/dev/null 2>&1; then
    log "Stopped any existing companion daemon before handoff"
  else
    log "Installed CLI stop command failed; continuing with daemon handoff"
  fi

  if "${node_bin}" "${APP_RUNTIME_DIR}/bin/cli.mjs" start -d >/dev/null 2>&1; then
    log "Started installed companion daemon after handoff"
  else
    log "Installed CLI start command failed; runtime handoff skipped"
  fi
}

launch_tray_once() {
  if [[ ! -x "${TRAY_BIN_PATH}" ]]; then
    log "Tray executable not found at ${TRAY_BIN_PATH}; skipping first launch"
    return 0
  fi
  open -g -a "${TRAY_APP_PATH}" >/dev/null 2>&1 || "${TRAY_BIN_PATH}" >/dev/null 2>&1 &
  log "Launched tray panel once for current user"
}

ensure_companion_config
register_native_host || true
restart_companion_daemon || true
write_startup_policy
remove_legacy_daemon_login_item
register_tray_login_item
launch_tray_once
EOS

sed -i '' "s/__COMPANION_VERSION__/${VERSION}/g" "${TMP_SCRIPT}"
chmod 755 "${TMP_SCRIPT}"

if su -l "${CONSOLE_USER}" -c "/bin/bash '${TMP_SCRIPT}'" >> "${LOG_FILE}" 2>&1; then
  echo "[$(date)] Companion bootstrap finished successfully." >> "${LOG_FILE}" 2>&1
  rm -f "${TMP_SCRIPT}"
  exit 0
else
  RC="$?"
  echo "[$(date)] Installer user bootstrap failed (exit=${RC}). Installation will continue; user can retry from extension Settings > Companion." >> "${LOG_FILE}" 2>&1
  rm -f "${TMP_SCRIPT}"
  exit 0
fi
