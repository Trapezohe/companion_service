{
  "name": "trapezohe-companion",
  "version": "0.1.18",
  "description": "Local companion daemon for Trapezohe AI — MCP server host & command runtime",
  "type": "module",
  "bin": {
    "trapezohe-companion": "./bin/cli.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "install.sh",
    "install.ps1",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/cli.mjs start",
    "test": "node --test",
    "build:installer:macos": "bash scripts/build-macos-pkg.sh",
    "build:installer:windows": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows-msi.ps1",
    "stage:tray:macos": "bash scripts/build-tray-macos.sh",
    "stage:tray:windows": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/build-tray-windows.ps1",
    "test:critical": "node scripts/test-critical.mjs"
  },
  "keywords": [
    "trapezohe",
    "mcp",
    "companion",
    "ai",
    "web3",
    "chrome-extension"
  ],
  "author": "Trapezohe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trapezohe/companion.git"
  },
  "homepage": "https://github.com/trapezohe/companion#readme"
}
